# ===========================================
# LoveApp Backend Environment Configuration
# ===========================================

# Environment
ENV=development

# ===========================================
# Database Configuration (SQLite)
# ===========================================
DB_PATH=./data/loveapp.db

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-please-make-it-very-long-and-secure

# ===========================================
# Server Configuration
# ===========================================
SERVER_PORT=8080

# ===========================================
# Docker Configuration
# ===========================================
BACKEND_PORT=8080
